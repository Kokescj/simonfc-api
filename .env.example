NODE_ENV=development
PORT=3000

# MongoDB connection string. Para desarrollo local con Docker:
# mongodb://localhost:27017/simonfc?replicaSet=rs0
DATABASE_URL=mongodb://localhost:27017/simonfc

# JWT — mínimo 32 caracteres. Generar con: openssl rand -base64 48
JWT_SECRET=replace-me-with-a-long-random-secret-at-least-32-chars
JWT_EXPIRES_IN=30m
REFRESH_TOKEN_EXPIRES_IN=30d

# Rate limiting global (override por endpoint en controllers)
THROTTLE_TTL=60000
THROTTLE_LIMIT=30

# Google Cloud Storage para fotos de perfil
GCS_BUCKET_NAME=simonfc-uploads

# CORS — orígenes permitidos en producción, separados por coma
CORS_ALLOWED_ORIGINS=
