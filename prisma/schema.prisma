generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// ============================================================================
// ENUMS
// ============================================================================

enum UserRole {
  admin
  supervisor
  usuario
}

enum MatchStatus {
  open       // Acepta inscripciones
  closed     // Cupo lleno o cerrado manualmente
  cancelled  // Cancelado por admin
  finished   // Partido jugado
}

// ============================================================================
// USUARIO Y AUTENTICACION
// ============================================================================

model User {
  id              String     @id @default(auto()) @map("_id") @db.ObjectId
  name            String
  lastName        String?    // Apellido
  jerseyName      String?    // Nombre que aparece en la camiseta
  preferredNumber Int?       // Número de jugador preferido
  photoUrl        String?    // URL de foto de perfil (GCS)
  email           String     @unique
  password        String
  roles           UserRole[] @default([usuario])
  status          String     @default("activo")
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  refreshTokens RefreshToken[]
  registrations MatchRegistration[]
  matchesCreated Match[]      @relation("MatchCreatedBy")
}

// OAuth 2.0 refresh token rotation con jti único + reuse detection.
model RefreshToken {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  jti       String   @unique
  userId    String   @db.ObjectId
  token     String   @unique // Hash bcrypt del refresh token completo
  expiresAt DateTime
  createdAt DateTime @default(now())
  isRevoked Boolean  @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

// ============================================================================
// PARTIDOS
// ============================================================================

model Match {
  id              String      @id @default(auto()) @map("_id") @db.ObjectId
  place           String      // Lugar del partido (ej: "Centro deportivo Laurita Vicuña")
  dateTime        DateTime    // Fecha y hora del partido
  requiredPlayers Int         // Cupo total (ej: 14 = 7 por equipo)
  notes           String?     // Notas opcionales del admin
  status          MatchStatus @default(open)

  createdById String @db.ObjectId
  createdBy   User   @relation("MatchCreatedBy", fields: [createdById], references: [id], onDelete: NoAction)

  registrations MatchRegistration[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([dateTime])
  @@index([status])
  @@index([createdById])
}

model MatchRegistration {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  matchId      String   @db.ObjectId
  userId       String   @db.ObjectId
  registeredAt DateTime @default(now())
  position     Int?     // Posición manual asignada por admin. null = orden por registeredAt.

  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([matchId, userId]) // Un jugador no puede inscribirse 2 veces al mismo partido
  @@index([matchId])
  @@index([userId])
  @@map("match_registrations")
}
